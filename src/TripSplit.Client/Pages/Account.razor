@page "/account"
@inject AuthApiClient AuthApi
@inject AuthenticationStateProvider AuthStateProvider

<div class="wrap">
  <div class="title-row">
    <div>
      <h1>My account</h1>
      <p class="sub">Your account details and password.</p>
    </div>
  </div>

  <AuthorizeView Context="authContext">
    <Authorized>
      @{ EnsureProfileLoaded(authContext.User); }
      <div class="card">
        <h2>
          Details
          @if (!_editingProfile)
          {
            <button class="info-icon" title="Edit details" @onclick="() => { _editingProfile = true; }">✎</button>
          }
        </h2>

        <div class="form-row-pair">
          <div class="form-row">
            <label for="firstName">First name</label>
            <InputText id="firstName" class="input-modern" @bind-Value="_profileModel.FirstName" disabled="@(!_editingProfile)"/>
          </div>
          <div class="form-row">
            <label for="lastName">Last name</label>
            <InputText id="lastName" class="input-modern" @bind-Value="_profileModel.LastName" disabled="@(!_editingProfile)"/>
          </div>
        </div>
        <div class="form-row">
          <label for="email">Email</label>
          <InputText id="email" class="input-modern" @bind-Value="_profileModel.Email" type="email" disabled="@(!_editingProfile)"/>
        </div>

        @if (_profileError is not null)
        {
          <p class="error-text">@_profileError</p>
        }

        @if (_editingProfile)
        {
          <div class="actions-row">
            <button class="btn" disabled="@_isSavingProfile" @onclick="SaveProfile">Save</button>
            <button class="btn secondary" disabled="@_isSavingProfile" @onclick="() => CancelEditingProfile(authContext.User)">Cancel</button>
          </div>
        }
      </div>

      <div class="card">
        <h2>Change password</h2>

        <EditForm Model="_model" OnValidSubmit="Submit">
          <div class="form-row">
            <label for="currentPassword">Current password</label>
            <InputText id="currentPassword" class="input-modern" @bind-Value="_model.CurrentPassword" type="password" placeholder="••••••••"/>
          </div>
          <div class="form-row">
            <label for="newPassword">New password</label>
            <input id="newPassword" class="input-modern" @bind="_model.NewPassword" @bind:event="oninput" type="password" placeholder="••••••••"/>
          </div>

          <PasswordRequirements Password="@_model.NewPassword"/>

          @if (_error is not null)
          {
            <p class="error-text">@_error</p>
          }
          @if (_success)
          {
            <p class="success-text">Password changed.</p>
          }

          <button class="btn" type="submit" disabled="@_isSubmitting">Change password</button>
        </EditForm>
      </div>
    </Authorized>
  </AuthorizeView>
</div>

@code {
  private readonly ChangePasswordModel _model = new();
  private string? _error;
  private bool _success;
  private bool _isSubmitting;

  private readonly UpdateProfileModel _profileModel = new();
  private bool _editingProfile;
  private bool _isSavingProfile;
  private string? _profileError;
  private bool _profileLoaded;

  // Populates the (always-visible, disabled-until-edited) fields from the
  // authenticated claims exactly once - re-running this on every render
  // would stomp in-progress edits before Save/Cancel commits or discards them.
  private void EnsureProfileLoaded(System.Security.Claims.ClaimsPrincipal user)
  {
    if (_profileLoaded) return;
    LoadProfile(user);
    _profileLoaded = true;
  }

  private void LoadProfile(System.Security.Claims.ClaimsPrincipal user)
  {
    _profileModel.FirstName = user.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ?? "";
    _profileModel.LastName = user.FindFirst(System.Security.Claims.ClaimTypes.Surname)?.Value ?? "";
    _profileModel.Email = user.Identity?.Name ?? "";
  }

  private void CancelEditingProfile(System.Security.Claims.ClaimsPrincipal user)
  {
    LoadProfile(user);
    _profileError = null;
    _editingProfile = false;
  }

  private async Task SaveProfile()
  {
    _isSavingProfile = true;
    _profileError = null;

    var result = await AuthApi.UpdateProfileAsync(_profileModel.FirstName, _profileModel.LastName, _profileModel.Email);
    _isSavingProfile = false;

    if (result.IsSuccess)
    {
      _editingProfile = false;
    }
    else
    {
      _profileError = result.Error;
    }
  }

  private async Task Submit()
  {
    _isSubmitting = true;
    _error = null;
    _success = false;

    var result = await AuthApi.ChangePasswordAsync(_model.CurrentPassword, _model.NewPassword);
    _isSubmitting = false;

    if (result.IsSuccess)
    {
      _success = true;
      _model.CurrentPassword = "";
      _model.NewPassword = "";
    }
    else
    {
      _error = result.Error;
    }
  }

  private class ChangePasswordModel
  {
    public string CurrentPassword { get; set; } = "";
    public string NewPassword { get; set; } = "";
  }

  private class UpdateProfileModel
  {
    public string FirstName { get; set; } = "";
    public string LastName { get; set; } = "";
    public string Email { get; set; } = "";
  }
}
