@page "/"
@page "/trip/{Id:guid?}"
@using System.Text.Json.Nodes
@using Microsoft.AspNetCore.Components.Forms
@using TripSplit.Shared.Import
@inject TripState TripState
@inject ToastService Toasts
@inject IJSRuntime JS
@implements IDisposable

<div class="wrap">
  <div class="title-row">
    <div>
      <h1>TripSplit</h1>
      <p class="sub">Split a shared trip cost across attendees, weighted by income and adjusted for local cost of living.</p>
    </div>
    <div class="import-export-row">
      <button class="btn secondary" @onclick="ExportTrip">Export trip</button>
      <label class="btn secondary" for="importFile" style="margin:0;">Import trip</label>
      <InputFile id="importFile" style="display:none" accept="application/json,.json" OnChange="OnImportFileSelected" />
    </div>
  </div>

  <ToastHost />

  <div class="tabs">
    <button class="tab-btn @(ActiveTab == "calc" ? "active" : "")" @onclick='() => SetTab("calc")'>Cost split calculator</button>
    <button class="tab-btn @(ActiveTab == "expenses" ? "active" : "")" @onclick='() => SetTab("expenses")'>Expenses</button>
    <button class="tab-btn @(ActiveTab == "split" ? "active" : "")" @onclick='() => SetTab("split")'>Trip split</button>
  </div>

  <div class="tab-panel @(ActiveTab == "calc" ? "active" : "")">
    <AttendeeTable />
    <ColAdjuster />
    <SplitDetails />
  </div>

  <div class="tab-panel @(ActiveTab == "expenses" ? "active" : "")">
    <ExpensesTable />
    <ExclusionTagsTable />
  </div>

  <div class="tab-panel @(ActiveTab == "split" ? "active" : "")">
    <SettleUp />
  </div>
</div>

@code {
  [Parameter] public Guid? Id { get; set; }

  private string ActiveTab = "calc";

  protected override void OnInitialized()
  {
    // No direct subscription to TripState.Changed here: this page's own
    // markup doesn't render any trip data (each tab's content is a child
    // component that refreshes itself via TripStateComponentBase).
    TripState.SaveFailed += OnSaveFailed;
  }

  protected override async Task OnParametersSetAsync()
  {
    if (Id is Guid id)
    {
      if (TripState.Trip.Id != id)
      {
        await TripState.LoadAsync(id);
      }
    }
    else if (!TripState.IsNew)
    {
      TripState.StartNewTrip();
    }
  }

  private void OnSaveFailed(string message) => Toasts.Show($"Save failed: {message}", isError: true);

  private void SetTab(string tab) => ActiveTab = tab;

  private async Task ExportTrip()
  {
    var json = TripState.BuildExportJson();
    var dateStamp = DateTime.UtcNow.ToString("yyyy-MM-dd");
    await JS.InvokeVoidAsync("tripSplitInterop.downloadFile", $"tripsplit-{dateStamp}.json", json, "application/json");
  }

  private async Task OnImportFileSelected(InputFileChangeEventArgs e)
  {
    try
    {
      using var stream = e.File.OpenReadStream(maxAllowedSize: 10_000_000);
      using var reader = new StreamReader(stream);
      var text = await reader.ReadToEndAsync();
      var raw = JsonNode.Parse(text);
      var result = TripImporter.ParseTripImport(raw);
      TripState.ApplyImport(result.Data);

      Toasts.Show(result.Skipped.Total > 0
        ? $"Imported with {result.Skipped.Total} row(s) skipped (missing required fields)."
        : "Trip imported successfully.");
    }
    catch (Exception ex)
    {
      Toasts.Show($"Import failed: {ex.Message}", isError: true);
    }
  }

  public void Dispose()
  {
    TripState.SaveFailed -= OnSaveFailed;
  }
}
