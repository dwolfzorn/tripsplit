@page "/forgot-password"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<div class="auth-page">
  <div class="auth-container">
    <h1 class="auth-brand">TripSplit</h1>
    <div class="auth-card">
      <h2>Forgot password</h2>
      <p class="sub">Self-service password reset isn't available yet. Contact an admin to have your password reset.</p>
      <div class="auth-links">
        <a href="/login">Back to log in</a>
      </div>
    </div>
  </div>
</div>
