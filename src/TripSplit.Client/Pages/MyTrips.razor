@page "/"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject TripApiClient Api
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<AuthorizeView>
  <Authorized>
    <div class="wrap">
      <div class="title-row">
        <div>
          <h1>My Trips</h1>
          <p class="sub">Trips you own or have been given access to.</p>
        </div>
        <div class="import-export-row">
          <button class="btn" @onclick="NewTrip">New trip</button>
        </div>
      </div>

      @if (_trips is null)
      {
        <p>Loading...</p>
      }
      else if (_trips.Count == 0)
      {
        <p>No trips yet. Start one!</p>
      }
      else
      {
        <table class="data-table">
          <thead>
            <tr><th>Trip</th><th>Role</th><th>Last updated</th></tr>
          </thead>
          <tbody>
            @foreach (var trip in _trips)
            {
              <tr>
                <td><a href="@($"/trip/{trip.Id}")">@trip.Title</a></td>
                <td>@trip.Role</td>
                <td>@trip.UpdatedAt.ToLocalTime().ToString("g")</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  </Authorized>
  <NotAuthorized>
    <p>Redirecting to login...</p>
  </NotAuthorized>
</AuthorizeView>

@code {
  private List<TripSummary>? _trips;

  protected override async Task OnInitializedAsync()
  {
    var authState = await AuthStateProvider.GetAuthenticationStateAsync();
    if (authState.User.Identity?.IsAuthenticated == true)
    {
      _trips = await Api.ListMineAsync();
    }
    else
    {
      Nav.NavigateTo("/login", replace: true);
    }
  }

  private void NewTrip() => Nav.NavigateTo("/trip");
}
