<ul class="password-requirements">
  @foreach (var rule in PasswordRules.All)
  {
    <li class="@(rule.IsMet(Password) ? "met" : "unmet")">
      <span class="requirement-icon">@(rule.IsMet(Password) ? "✓" : "✗")</span>
      @rule.Description
    </li>
  }
</ul>

@code {
  [Parameter] public string Password { get; set; } = "";
}
